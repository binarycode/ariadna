{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "espup@latest",
    "just@latest",
    "ldproxy@latest",
    "llvmPackages.libclang@latest",
    "libiconv@latest",
    "nodejs@latest",
    "prettier@latest",
    "rustup@latest",
    "shfmt@latest",
    "taplo@latest",
    "treefmt@latest"
  ],
  "env": {
    "NPM_CONFIG_CACHE": "${PWD}/.devbox/npm-cache",

    "PATH": "${PATH}:${PWD}/bin",

    "ESPUP_EXPORT_FILE": "${PWD}/.devbox/export-esp.sh",
    "RUSTUP_HOME": "${PWD}/.devbox/.rustup",

    },
  "shell": {
    "init_hook": [
      "if [ -f \"$ESPUP_EXPORT_FILE\" ]; then . \"$ESPUP_EXPORT_FILE\"; fi",
      "export LIBCLANG_PATH=\"$(nix-store -qR \"$(which clang)\" 2>/dev/null | grep 'clang.*-lib$' | head -1)/lib\""
    ],
    "scripts": {
      "check": "export LIBCLANG_PATH=$(nix-store -qR $(which clang) 2>/dev/null | grep 'clang.*-lib$' | head -1)/lib && just check",
      "test": "export LIBCLANG_PATH=$(nix-store -qR $(which clang) 2>/dev/null | grep 'clang.*-lib$' | head -1)/lib && just test",
      "fmt": "just fmt"
    }
  }
}
